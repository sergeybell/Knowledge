#-------Free Space in Regular Cell------------------------------
oo	L[cm]=$L_odd
oo2	L[cm]=$L_odd/2
oq	L[cm]=$L_oq
od	L[cm]=$L_od
#----------------------------------drift in hor-dispersion supressor---
o_miss	L[cm]=$L_miss


O_det 	L[cm]=525   
C_MPD	L[cm]=525	B[kG]=5
C_SPD	L[cm]=525	B[kG]=0
C_EC		L[cm]=$L_EC	B[kG]=2

#--------Straight section "large" drifts-----------------------------------
oS1                      L[cm]=$L_oS1
oS2                      L[cm]=$L_oS2
oS3                      L[cm]=$L_oS3

o_EC                    L[cm]=$L_oS1/2 - $L_EC/2


#---------------drift between vertical bending magnets---------------------
ObV12                  L[cm]=$Lvb12-$LbV

#----------Vertical bending dipoles------------------------------------------
BV1W 	L[cm]=$LbV     	B[kG]=-$BbV    	G[kG/cm]=0        	Tilt[deg]=90
BV2W2 	L[cm]=$LbV     	B[kG]=$BbV   	G[kG/cm]=0        	Tilt[deg]=90

BV4W 	L[cm]=$LbV     	B[kG]=-$BbV    	G[kG/cm]=0        	Tilt[deg]=90
BV3W2 	L[cm]=$LbV     	B[kG]=$BbV   	G[kG/cm]=0        	Tilt[deg]=90


BV1E 	L[cm]=$LbV     	B[kG]=-$BbV    	G[kG/cm]=0        	Tilt[deg]=90
BV2E2 	L[cm]=$LbV     	B[kG]=$BbV   	G[kG/cm]=0        	Tilt[deg]=90

BV4E 	L[cm]=$LbV     	B[kG]=-$BbV    	G[kG/cm]=0        	Tilt[deg]=90
BV3E2 	L[cm]=$LbV     	B[kG]=$BbV   	G[kG/cm]=0        	Tilt[deg]=90

end list of elements




BetaFitBlock dL[cm]=0.01 dB[kG]=0.01 dG[kG/cm]=0.00000001 

#Required parameters and their accuracy listed below(dPARM<=0. - no fitting)
#Maximum Betas[cm] and MomentumCompaction are on the next line

BtXmax=50000.  dBtXmax=-0.1  BtYmax=50000.  dBtYmax=-0.1  Alfa=0.05  dAlfa=0
#Fitting parameters at the end of the lattice

Beta_X[cm]=60   dBeta_X[cm]=0.001    Alfa_X=0.0         dAlfa_X=0.0001
Beta_Y[cm]=60    dBeta_Y[cm]=0.001    Alfa_Y=0.0         dAlfa_Y=0.0001

Disp_X[cm]=0.0     dDisp_X[cm]=0   D_prime_X=0     dD_prime_X=0
Disp_Y[cm]=0.0      dDisp_Y[cm]=0   D_prime_Y=0       dD_prime_Y=0

Qx=0.9409                dQx=0.000001
Qy=0.8620                      dQy=0.000001

#Insert groups of elements below. Each group has to be located on one line.
#Start from the letter describing the type of changable parameter such as: L:, B:, G: 
#---------------fit for beta-f-at-IP---ajustment
G:QFF1W  min=-1e10   max=1e10
#-----------closed when tune fitting
#G:QFF2W  min=-1e10   max=1e10
#G:QFF3W  min=-1e10   max=1e10
G:Q39W2  min=-1e+10 max=1e+10                                      
# Q39W2Can be open in tune-fitting!!
#---------------end group for fit for beta-f-at-IP---ajustment

#--------------fit for SS tune ajustment-------
G:Q38W2  min=-1e10   max=1e10

G:Q37W2  min=-1e10   max=1e10

G:Q34W2  min=-1e10   max=1e10

G:Q33W2  min=-1e10   max=1e10

G:Q32W2  min=-1e10   max=1e10

EndBetaFitBlock


4D_BetaBlock
	Beta_X_1[cm]=60.4887 	Beta_X_2[cm]=0.938378
	Alfa_X_1=-0.0384148  	Alfa_X_2=0.00558224
	Beta_Y_1[cm]=0.856914 	Beta_Y_2[cm]=61.8013
	Alfa_Y_1=0.00655971  	Alfa_Y_2=0.0213282
	Teta_1[deg]=164.081      	Teta_2[deg]=164.972      	U=-0.0131365  
	Emit1[cm]=$EmitX  	Emit2[cm]=$EmitZ
	DispX[cm]=-1.1802      	DispY[cm]=-0.0420682  
	DispXpr[cm]=-0.00387732  	DispYpr[cm]=-0.000764054
End4DBetaBlock


TrajParamBlock
	X[cm]=0.0 	Teta_X[rad]=0.0
	Y[cm]=0.0 	Teta_Y[rad]=0.0
	s[cm]=0.0 	DeltaP/P=$dp_p
