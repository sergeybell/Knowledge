
# ---------- BEAM PARAMETERS ----------
$E0=4500;  =>        4500
$Mp = 939.205;  =>     939.205
$Z=79;  =>          79
$A=197;  =>         197

$Mu0=4*$pi*10^(-7);  =>1.25663706e-06

$gamma=($Mp+$E0)/$Mp;  =>  5.79128625
$beta=sqrt(1-1/$gamma^2);  => 0.984979168

$P0=$Mp*$gamma*$beta;  =>  5357.50362
$Bro=$A/$Z*$P0/$c*1e11;  =>  44563.6654

$EmitX=1*10^(-4);  =>      0.0001
$EmitZ=1*10^(-4);  =>      0.0001
# Beam emittances [cm] ( /$pi*0.1*0.001 - converts X in Pi*mm*mrad -> cm ( * rad ) )


$dp_p=0.01;  =>        0.01

$Accept=40e-4;  =>       0.004
$SigmaP=2.5e-3;  =>      0.0025
$P_Accept=1.25e-2;  =>      0.0125


#-----------DIPOLES-----------------------------
$N_d=80;  =>          80  # Number of dipoles in the ring
$L_d=194;  =>         194  # Effective length of the dipole magnet [cm]
$h_d=7.2;  =>         7.2  # Vertical apperture of the dipoles [cm]
$Nt_d=10;  =>          10  # Number of turns in dipoles' coil (full)


$B_d = 2*$pi*$Bro/$N_d/$L_d;  =>   18.041351  #  [kG] Magnetic field in the dipoles for fixed $E0

$I_d = ($B_d/10) * ($h_d/100) / ($Mu0 * $Nt_d);  =>  10336.9327  # [A] dipoles current

$B_d_check = ($I_d * $Nt_d) * $Mu0 / ($h_d/100) *10;  =>   18.041351


$FiEdge = 1/2*$B_d*$L_d/$Bro*180/$pi;  =>        2.25  # [degree] half of the dipoles' bending angle


$D="od   Hd g bH g Hd    oo    Hd g bH g Hd  od";




#------------QUADS-------------------------------
$L_q=47;  =>          47  # Length of the main quad in regular cell [cm]
$r_q=4.75;  =>        4.75  # Radius of the inscribed circle in the quad aperture [cm]
$Nt_q=4;  =>           4  # Number of turns in quad coil (full)

$r_q_ff=9.0;  =>           9  # Radius of the inscribed circle in the final focus quad aperture [cm]
$Nt_q_ff=12;  =>          12  # Number of turns in quad coil (full)

$G_q = 2*$Mu0*$Nt_q/2*$I_d/($r_q/100)^2;  =>    23.02896  # [T/m] quads gradient for I=$I_d analytically calculated



#----------------regular quads-------------------
$G_qF =2.294302*10;  =>    22.94302  # [T/m] actual gradient taken after cell fitting to Qx=Qy=0.25  (Cell---7-fit---B-dip-positive file)

$dI_q = $G_qF*(($r_q/100)^2) / (2*$Mu0*$Nt_q/2) - $I_d;  => -38.5755859  # [A] additional current for F- and D- quads

$G_qF_check = 2*$Mu0*$Nt_q/2*($I_d + $dI_q)/($r_q/100)^2;  =>    22.94302

$G_qF_ = $G_qF_check/10;  =>    2.294302




$G_qD=2.24472*10;  =>     22.4472  # [T/m] actual (ABSolute value) gradient taken after cell fitting to Qx=Qy=0.25   (Cell---7-fit---B-dip-positive file)

$dI_qD = $G_qD*(($r_q/100)^2) / (2*$Mu0*$Nt_q/2) - $I_d - $dI_q;  => -222.557075

$G_qD_check = (-1) * 2*$Mu0*$Nt_q/2*($I_d + $dI_q + $dI_qD)/($r_q/100)^2;  =>    -22.4472

$G_qD_ = $G_qD_check/10;  =>    -2.24472



#---------------------hor-dispersion supressor-------
$G_qF1 =2.205706*10;  =>    22.05706  # [T/m] F1 gradient taken after 6-cell line fitting to Dx=0 at the end 
$G_qF2 =1.81916*10;  =>     18.1916  # [T/m] F2 gradient taken after 6-cell line fitting to Dx=0 at the end

$dI_qF1 = $G_qF1*(($r_q/100)^2) / (2*$Mu0*$Nt_q/2) - $I_d;  => -436.253506  # [A] additional current for F1- quad in Dx supressor cell

$G_qF1_check = 2*$Mu0*$Nt_q/2*($I_d + $dI_qF1)/($r_q/100)^2;  =>    22.05706

$G_qF1_ = $G_qF1_check/10;  =>    2.205706



$dI_qF2 = $G_qF2*(($r_q/100)^2) / (2*$Mu0*$Nt_q/2) - $I_d;  => -2171.32968  # [A] additional current for F2- quad in Dx supressor cell

$G_qF2_check = 2*$Mu0*$Nt_q/2*($I_d + $dI_qF2)/($r_q/100)^2;  =>     18.1916

$G_qF2_ = $G_qF2_check/10;  =>     1.81916




