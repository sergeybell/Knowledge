# This file is based on the optics measurements performed on Agust 22 and 29.
# Beam envelopes in E sector were additionally adjusted to match the tune shift measurements
#========================================================
# Power supply currents
# ----------------------
# Before optics correction attemp
#include quad.crt 
$T:Q39S=0;  =>           0
$T:Q39C=0;  =>           0
#========================================================
# Controls for Optics 
# ----------------------
# Horizontal and vertical tune correction
$dQh=      -0.005
$dQv=       0.01
#---------------
# Beam envelope correction (A)
# X (A44 + A46)
$diAQ9=           0
$diAQ7=    0;  =>           0
$diB0Q3T =          0
$diQB15=          0
# Y (B14 + B16)
$diBQ7=    0;  =>           0
$diBQ9=    0;  =>           0
$diB0Q2T = 0;  =>           0
#
$diB0Q2 = 0;  =>           0
$diB0Q3 =  0;  =>           0
#-------------------
# X (C44 + C46)
$diCQ9=          0
$diCQ7=           0
$diD0Q3T =          -1
$diQD15=          20
# Y (D14 + D16)
$diDQ7=         -30
$diDQ9=          50
$diD0Q2T =           0
#
$diD0Q2 =0;  =>           0
$diD0Q3 =0;  =>           0
#---------------
# B0 and D0 alpha bumps
$AlphaB0h=         0;  =>           0
$AlphaB0v=         0;  =>           0
$AlphaD0h=         0;  =>           0
$AlphaD0v=         0;  =>           0
#---------------
# Additions to Skew-quads (A)
$diKSQ    =         1.9
$diKSQA0=      -2.776
$diKSQA4= 0;  =>           0
$diKSQB1= 0;  =>           0
$diKSQD0= 0;  =>           0
$diKSQE0= 0;  =>           0
# Tune changes for beta-function measurements
$didQX1_E17=          0
$didQX2_E19=          0;  =>           0
$didQY1_E47=          0
$didQY2_F33=          0;  =>           0
# Tune change for beta-function measurements with QXR quads
$iT:E0QT=          0;  =>           0
$iT:E1QT=          0;  =>           0
$iT:C0QT=          0;  =>           0
#========================================================
# Helix excitation and control
# ----------------------
$psext=1;  =>           1  # nonlinearity switch
#
$psgn  = 0;  =>           0  # Helix switch; $psgn=1 for proton helix; -1 for pbar helix;
$Xh=      -0.332688;  =>   -0.332688
$TXh=     0.592839;  =>    0.592839
$Yh=      0.366022;  =>    0.366022
$TYh=     0.327388;  =>    0.327388
#========================================================
# Block for differential orbit studies
#------------------------------------------
# Initial coordinates for differntial orbits
$X1x=       0.185;  =>       0.185
$TX1x=       0.249;  =>       0.249
$Y1x=       0.014;  =>       0.014
$TY1x=    -0.00049;  =>    -0.00049
#
$X1y=      0.0007;  =>      0.0007
$TX1y=    -0.00093;  =>    -0.00093
$Y1y=       0.1496;  =>      0.1496
$TY1y=       -0.0875;  =>     -0.0875
#
$X2x=      -0.014;  =>      -0.014
$TX2x=       0.178;  =>       0.178
$Y2x=      0.0029;  =>      0.0029
$TY2x=     -0.0048;  =>     -0.0048
#
$X2y=      -0.005;  =>      -0.005
$TX2y=       0.006;  =>       0.006
$Y2y=       0.021;  =>       0.021
$TY2y=      -0.264;  =>      -0.264
#
#$DeltaP0=80/53.1e6/0.0029*1000 ;  => 0.519514254
$XD=      -0.117;  =>      -0.117
$TXD=      -0.066;  =>      -0.066
$YD=     -0.0023;  =>     -0.0023
$TYD=     -0.0145;  =>     -0.0145
$DeltaP0=       -0.48;  =>       -0.48
#------------------------------------------
$Ax=        1;  =>           1
$Ay=       1.;  =>           1
#========================================================
# Block for optics correcions
#------------------------------------------
# Global corrections
$F_bendq=         -16
$GdLskewUn=        2.25
$GdLskewUn0=       0;  =>           0
$SdLunits= -5.0;  =>          -5  # Sextupole in main dipole
$F_mq=        0.11
