$TX=($TX1x*$p1x + $TX1y*$p1y +$TX2x*$p2x+ $TX2y*$p2y + $TXD*$pd +   $TXh*$psgn)*0.0001;  =>       6e-07
$Y=    $Y1x*$p1x  +  $Y1y*$p1y  +  $Y2x*$p2x  +   $Y2y*$p2y   +  $YD*$pd    +   $Yh*$psgn;  =>       0.021
$TY=($TY1x*$p1x +$TY1y*$p1y +$TY2x*$p2x  + $TY2y*$p2y + $TYD*$pd  +   $TYh*$psgn)*0.0001;  =>   -2.64e-05
