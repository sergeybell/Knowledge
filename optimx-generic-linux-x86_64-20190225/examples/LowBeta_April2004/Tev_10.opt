  $P0=$iT:A2DCV1*225.459;  =>  979529.083
  $E0=sqrt($P0^2 + $Mp^2)-$Mp;  =>  978591.253
  $gamma=1+$E0/$Mp;  =>  1043.96337
  $beta=sqrt(1-1/$gamma/$gamma);  => 0.999999541
  $Hr=$P0/$c*1e11;  =>  3267357.32
$EmitN=0.0020/6;  =>0.000333333333
  $Emit=$EmitN/($gamma*$beta);  =>3.19296152e-07
  $AcceptN=$EmitN*6;  =>       0.002
  $Accept=$Emit*6;  =>1.91577691e-06
$DPoverP=1.27e-4;  =>    0.000127
