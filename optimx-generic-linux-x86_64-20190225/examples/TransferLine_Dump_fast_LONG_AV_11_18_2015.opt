# PIP-II Transfer Line.  
# This line starts right at the end of the 4th HB 650 MHz Cryomodule of the linac.  
# and ends with the foil for electron stripping in the Booster  
$MASS_Hminus=939.294;  =>     939.294
$E0=800;  =>         800
$P0= sqrt(($E0+$MASS_Hminus)^2-$MASS_Hminus^2);  =>  1463.85464  # MeV/c   
$gamma=sqrt(($P0^2/$MASS_Hminus^2) + 1);  =>  1.85170351
$beta=sqrt(1-1/$gamma/$gamma);  => 0.841637261
$Brho=$P0/$c*1e11;  =>  4882.89348  # kG*cm      
#-------------------------     
# dipoles     
$Ndip = 32;  =>          32
$Bdip_1 = 2.35911566;  =>  2.35911566  # kG    
$Angle_1 = 217.0018536566120/ $Ndip;  =>  6.78130793  # deg    
$x_1 = 360-217.0018536566120;  =>  142.998146  #deg     
$Ldip_1 = $PI*$Angle_1/180*$Brho/$Bdip_1;  =>  244.973355  # cm     
$Bdip = 2.6689319807;  =>  2.66893198  # kG    
$Angle = 2.0*asin($Bdip/$Bdip_1*sin($Angle_1*$PI/360));  => 0.133921462
$Ldip = $Angle*$Brho/$Bdip;  =>   245.01345
$Angle = 180/$PI/$Brho*$Bdip*$Ldip;  =>  7.67313455
# dipole parameters     
$J=3 ;  =>           3  # A/mm^2     
$gap_dip=4 ;  =>           4  # cm     
$Itot= $Bdip * $gap_dip/ (0.4*$PI)*1000;  =>  8495.47435  # A   
$Nturns=10;  =>          10
$Lturns=$Nturns*4*(20+$Ldip)/100;  =>   106.00538  # m     
$Sturn=$Itot/$Nturns/$J;  =>  283.182478  # mm^2     
$Rcoil = 0.02*$Lturns/$Sturn;  =>0.00748671886  # Ohm    
$I=$Itot/$Nturns;  =>  849.547435  # A     
$U=$Rcoil*$I;  =>   6.3603228  # V    
$P=$Rcoil*$I^2;  =>  5403.39592  # W      
$Scoil=$Sturn*$Nturns*0.01/0.5;  =>  56.6364957  # cm^2    
$P_tot=$P*$Ndip;  =>   172908.67
#----------------------     
# Quadrupole Field      
$GF=0.6670326148 ;  => 0.667032615  #kG/cm    ;    
$GD=-0.7838559465 ;  =>-0.783855947  #kG/cm    ;    
$Lq=20;  =>          20
$FIqf=$GF*$Lq/$Brho*100;  => 0.273212028  #1/m     
$FIqf=$GF / $Brho*1e4;  =>  1.36606014  # 1/m^2     
$FIqd=$GD*$Lq/$Brho*100;  =>-0.321062071  #1/m     
$FIqd=$GD / $Brho*1e4;  => -1.60531036  # 1/m^2     
#----------------------     
# Dipoles for switch to d line        
# Fast switch for energy measurement      
$swdf=1;  =>           1  # (1-ON, 0-OFF)    
$Angle_DFK=0.0070593631;  =>0.0070593631  # rad 
$L_DFK=150*(1+$swdf*($Angle_DFK/sin($Angle_DFK)-1));  =>  150.001246  # cm    
$Angle_DFK=$Angle_DFK*$swdf;  =>0.0070593631  # rad    
$B_DFK=$Brho/$L_DFK*$Angle_DFK;  => 0.229798878  # kG    
$Angle_DFK=$Angle_DFK/$PI*180;  => 0.404471712  # deg    
$swds=0;  =>           0  # (1-ON, 0-OFF)    
$Angle_DSK=0.0156451265;  =>0.0156451265  # rad 
$L_DSK=100*(1+$swds*($Angle_DSK/sin($Angle_DSK)-1));  =>         100  # cm    
$Angle_DSK=$Angle_DSK*$swds;  =>           0  # rad    
$B_DSK=$Brho/$L_DSK*$Angle_DSK;  =>           0  # kG    
$Angle_DSK=$Angle_DSK/$PI*180;  =>           0  # deg    
$Angle_DSC=-0.0085887089;  =>-0.0085887089  # rad 
$L_DSC=50*(1+$swds*($Angle_DSC/sin($Angle_DSC)-1));  =>          50  # cm    
$Angle_DSC=$Angle_DSC*$swds;  =>          -0  # rad    
$B_DSC=$Brho/$L_DSC*$Angle_DSC;  =>          -0  # kG    
$Angle_DSC=$Angle_DSC/$PI*180;  =>          -0  # deg    
# Quadrupole of the d switch section   
$B_qFd=$GF*3.1639999995*($swdf+$swds);  =>  2.11049119  # kG      
$Angle_bqFd=$B_qFd/$Brho*$Lq/$PI*180;  => 0.495289273  #deg    
# Lertson magnet for d line  
$Angle_Ld=0.15;  =>        0.15  # rad   
$L_Ld=270*(1+($Angle_Ld/sin($Angle_Ld)-1)*($swdf+$swds));  =>  271.015164  # cm   
$Angle_Ld=$Angle_Ld*($swdf+$swds);  =>        0.15  # rad   
$B_Ld=$Brho/$L_Ld*$Angle_Ld;  =>  2.70255734  # kG   
$Angle_Ld=$Angle_Ld/$PI*180;  =>  8.59436693  # deg   
#sweeping dipole       
$Anglesweep=0.07/3;  =>0.0233333333  # rad       
$Lsweep=50*$Anglesweep/sin($Anglesweep);  =>  50.0045373  # cm      
$Bsweep=$Brho/$Lsweep*$Anglesweep;  =>  2.27847686  # kG     
$Anglesweep=$Anglesweep/$PI*180;  =>  1.33690152  # deg
# Correctors
$swk=0;  =>           0  # (1-ON, 0-OFF)    
#------------------   
# Emittance   
$AcceptN=10^2*0.25e-4;  =>      0.0025
$Accept=$AcceptN/($gamma*$beta);  =>0.00160414493
$DPoverPtot=0.0002;  =>      0.0002
#========================================    
OptiM      
Energy[MeV]=$E0   Mass[MeV]=$MASS_Hminus    
Emittance: ex[cm]=$Accept  ey[cm]=$Accept  DP/P=$DPoverPtot    
Initial:	BetaX[cm]=1324.44	BetaY[cm]=2075.65   
	AlfaX=-0.4335	AlfaY=-1.6085    
	DispersX[cm]=0 	DispersY[cm]=0    
	Dsp_PrimeX=0 	DspPrimeY=0 	  
	X[cm]=3030668.162 Y[cm]=22143.19354  Z[cm]=3057544.409   S[cm]=0    
                tetaX[deg]=-83.02072818202521       tetaY[deg]=0          
